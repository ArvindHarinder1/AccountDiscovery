# Account Discovery — Configuration
# Copy this file to .env and fill in your values

# ── Data Source ──
# "local" = read from CSV files in data/ (default for customers)
# "kusto" = read from Azure Data Explorer
# "graph" = read from Microsoft Graph API (correlation reports)
DATA_SOURCE=local

# ── AI Provider ──
# "none" = skip AI analysis (Tier 1 + Tier 2 only)
# "azure_openai" = use Azure OpenAI for Tier 3 (requires az login)
AI_PROVIDER=none

# ── Azure OpenAI (only if AI_PROVIDER=azure_openai) ──
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Azure Data Explorer / Kusto (only if DATA_SOURCE=kusto) ──
KUSTO_CLUSTER_URI=
KUSTO_DATABASE=accounts
KUSTO_TENANT_ID=
KUSTO_SUBSCRIPTION_ID=

# ── Microsoft Graph (only if DATA_SOURCE=graph) ──
GRAPH_TENANT_ID=
GRAPH_SUBSCRIPTION_ID=
GRAPH_SERVICE_PRINCIPAL_ID=

# ── Matching Thresholds ──
MATCH_THRESHOLD_HIGH=80
MATCH_THRESHOLD_MEDIUM=50
MATCH_THRESHOLD_LOW=25
